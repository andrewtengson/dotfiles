# pi extension and script tooling

# pi extension and script tooling

dir := justfile_directory()

# Format all TypeScript files
fmt:
    cd {{dir}} && bunx @biomejs/biome format --write extensions/ sync-kiro-models.ts

# Lint all TypeScript files
lint:
    cd {{dir}} && bunx @biomejs/biome check extensions/ sync-kiro-models.ts

# Format + lint (fix what's auto-fixable)
check:
    cd {{dir}} && bunx @biomejs/biome check --write extensions/ sync-kiro-models.ts

# Sync Kiro model catalog into pi-provider-kiro
sync-kiro:
    cd {{dir}} && bun sync-kiro-models.ts
