# pi extension tooling

dir := justfile_directory()

# Format all TypeScript files
fmt:
    cd {{dir}} && bunx @biomejs/biome format --write extensions/

# Lint all TypeScript files
lint:
    cd {{dir}} && bunx @biomejs/biome check extensions/

# Format + lint (fix what's auto-fixable)
check:
    cd {{dir}} && bunx @biomejs/biome check --write extensions/
